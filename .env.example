# Sekunet Chat - Variables de entorno
# Copia este archivo a .env.local y completa con tus credenciales

# Supabase (https://app.supabase.com -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://kzcyxeracvfxynddyjld.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# URL pública del sitio (para callbacks/webhooks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# IA - Google Gemini (https://ai.google.dev/gemini-api/docs/api-key)
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# Evolution API (Integración Principal de WhatsApp)
# URL base del servidor Evolution (ej: http://localhost:7001)
EVOLUTION_API_URL=
# API Key configurada en Evolution (header apikey)
EVOLUTION_API_KEY=
# Nombre de la instancia creada en Evolution (instanceName)
EVOLUTION_INSTANCE=
